# =============================================================================
# dbt + Databricks Field Enablement — Environment Configuration
# =============================================================================
# Copy this file to .env and update with your workspace values.
# Each user/team should use a UNIQUE catalog or schema prefix to avoid collisions.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env
#   cd platform && dbt build

# -- Databricks connection --
DBX_HOST=https://your-workspace.cloud.databricks.com
DBX_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
DBX_TOKEN=dapi_your_token_here

# -- Unity Catalog namespace --
# Change these to avoid collisions with other users in the same workspace.
# Example: use your name or team as a suffix — "enablement_alice", "ecommerce_team_a"
DBT_CATALOG=enablement
DBT_SCHEMA=ecommerce

# -- CI/CD (GitHub Actions) --
# Set these as GitHub repository secrets, not in .env
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_CLIENT_ID=your_service_principal_client_id
# DATABRICKS_CLIENT_SECRET=your_service_principal_client_secret
